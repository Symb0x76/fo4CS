{
	"version": 3,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 21,
		"patch": 0
	},
	"configurePresets": [
		{
			"name": "common",
			"hidden": true,
			"cacheVariables": {
				"F4SE_SUPPORT_XBYAK": "ON",
				"FRAMEGEN": true,
				"UPSCALER": true
			},
			"binaryDir": "${sourceDir}/build"
		},
		{
			"name": "vcpkg",
			"hidden": true,
			"cacheVariables": {
				"CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
				"VCPKG_TARGET_TRIPLET": "x64-windows-static-md"
			}
		},
		{
			"name": "win64",
			"hidden": true,
			"architecture": "x64",
			"cacheVariables": {
				"CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL"
			}
		},
		{
			"name": "msvc",
			"hidden": true,
			"cacheVariables": {
				"CMAKE_CXX_FLAGS": "/EHsc /MP /W4 /WX $penv{CXXFLAGS}",
				"CMAKE_C_COMPILER": "cl",
				"CMAKE_CXX_COMPILER": "cl"
			},
			"environment": {
				"CC": "cl",
				"CXX": "cl"
			},
			"generator": "Visual Studio 17 2022",
			"vendor": {
				"microsoft.com/VisualStudioSettings/CMake/1.0": {
					"intelliSenseMode": "windows-msvc-x64",
					"enableMicrosoftCodeAnalysis": true,
					"enableClangTidyCodeAnalysis": true
				}
			}
		},
		{
			"name": "Framegen",
			"hidden": true,
			"cacheVariables": {
				"FRAMEGEN": true,
				"UPSCALER": false
			}
		},
		{
			"name": "Upscaler",
			"hidden": true,
			"cacheVariables": {
				"FRAMEGEN": false,
				"UPSCALER": true
			}
		},
		{
			"name": "all",
			"hidden": true,
			"cacheVariables": {
				"FRAMEGEN": true,
				"UPSCALER": true
			}
		},
		{
			"name": "PreNG",
			"displayName": "PreNG",
			"binaryDir": "${sourceDir}/build/PreNG",
			"cacheVariables": {
				"BUILD_PRE_NG": true,
				"BUILD_POST_NG": false,
				"BUILD_POST_AE": false
			},
			"inherits": [
				"common",
				"all",
				"vcpkg",
				"win64",
				"msvc"
			]
		},
		{
			"name": "PostNG",
			"displayName": "PostNG",
			"binaryDir": "${sourceDir}/build/PostNG",
			"cacheVariables": {
				"BUILD_PRE_NG": false,
				"BUILD_POST_NG": true,
				"BUILD_POST_AE": false
			},
			"inherits": [
				"common",
				"all",
				"vcpkg",
				"win64",
				"msvc"
			]
		},
		{
			"name": "PostAE",
			"displayName": "PostAE",
			"binaryDir": "${sourceDir}/build/PostAE",
			"cacheVariables": {
				"BUILD_PRE_NG": false,
				"BUILD_POST_NG": false,
				"BUILD_POST_AE": true
			},
			"inherits": [
				"common",
				"all",
				"vcpkg",
				"win64",
				"msvc"
			]
		}
	],
	"buildPresets": [
		{
			"name": "pre-ng-debug",
			"configurePreset": "PreNG",
			"configuration": "Debug",
			"displayName": "Debug"
		},
		{
			"name": "pre-ng-release",
			"configurePreset": "PreNG",
			"configuration": "Release",
			"displayName": "Release"
		},
		{
			"name": "pre-ng-relwithdebinfo",
			"configurePreset": "PreNG",
			"configuration": "RelWithDebInfo",
			"displayName": "RelWithDebInfo"
		},
		{
			"name": "pre-ng-minsizerel",
			"configurePreset": "PreNG",
			"configuration": "MinSizeRel",
			"displayName": "MinSizeRel"
		},
		{
			"name": "post-ng-debug",
			"configurePreset": "PostNG",
			"configuration": "Debug",
			"displayName": "Debug"
		},
		{
			"name": "post-ng-release",
			"configurePreset": "PostNG",
			"configuration": "Release",
			"displayName": "Release"
		},
		{
			"name": "post-ng-relwithdebinfo",
			"configurePreset": "PostNG",
			"configuration": "RelWithDebInfo",
			"displayName": "RelWithDebInfo"
		},
		{
			"name": "post-ng-minsizerel",
			"configurePreset": "PostNG",
			"configuration": "MinSizeRel",
			"displayName": "MinSizeRel"
		},
		{
			"name": "post-ae-debug",
			"configurePreset": "PostAE",
			"configuration": "Debug",
			"displayName": "Debug"
		},
		{
			"name": "post-ae-release",
			"configurePreset": "PostAE",
			"configuration": "Release",
			"displayName": "Release"
		},
		{
			"name": "post-ae-relwithdebinfo",
			"configurePreset": "PostAE",
			"configuration": "RelWithDebInfo",
			"displayName": "RelWithDebInfo"
		},
		{
			"name": "post-ae-minsizerel",
			"configurePreset": "PostAE",
			"configuration": "MinSizeRel",
			"displayName": "MinSizeRel"
		}
	]
}